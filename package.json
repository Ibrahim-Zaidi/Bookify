{
  "name": "ecommerce_website",
  "version": "1.0.0",
  "main": "index.js",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "prebuild": "rm -rf Server/dist",
    "build": "npm run build-client && npm run build-server",
    "postbuild": "npm run copy-client",
    "build-client": "cd Client && npm install && npm run build",
    "build-server": "cd Server && npm install && npm run build",
    "copy-client": "fs-extra copy Client/dist Server/dist/public",
    "start": "cd Server && npm start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "full-Stack Bookify website",
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
