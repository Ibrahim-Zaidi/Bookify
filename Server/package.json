{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "npx prisma generate && node dist/index.js",
    "build": "node -e \"const { build } = require('esbuild'); const pkg = require('./package.json'); build({ entryPoints: ['src/index.ts'], bundle: true, platform: 'node', outfile: 'dist/index.js', external: Object.keys(pkg.dependencies) });\"",
    "postinstall": "npm run build && npx prisma generate"
  },
  "keywords": [],
  "author": "Ibrahim Zaidi",
  "license": "ISC",
  "description": "Bookify Backend",
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "@types/cookie-parser": "^1.4.8",
    "bcrypt": "^5.1.1",
    "body-parser": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "esbuild": "^0.25.10",
    "express": "^5.1.0",
    "google-auth-library": "^10.3.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.14.1",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-local": "^1.0.38",
    "prisma": "^6.15.0",
    "ts-node-dev": "^2.0.0"
  }
}
